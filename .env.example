# Convex
NEXT_PUBLIC_CONVEX_URL=           # From `npx convex dev` output

# Clerk (keyless mode works for local dev; these are REQUIRED for production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= # Clerk Dashboard > API Keys
CLERK_SECRET_KEY=                  # Clerk Dashboard > API Keys

# GitHub Issues (for contact/bug report forms)
GITHUB_TOKEN=                    # Fine-grained PAT with Issues: Read and write scope
GITHUB_OWNER=                    # GitHub repo owner (e.g., "username")
GITHUB_REPO=                     # GitHub repo name (e.g., "marko")

# Convex environment variables (set via `npx convex env set`):
# CLERK_SECRET_KEY — Required for account deletion (Clerk Backend API)
# CLERK_WEBHOOK_SECRET — For Clerk webhook verification
# ANTHROPIC_API_KEY — Required for AI document actions (summarize, translate, extract, improve)
